# AI Insights feature — copy this file to .env and fill in your key.
# The rest of the tool works without this; the AI tab shows a setup notice when the key is missing.
#
# Supported providers: anthropic | openai | gemini
#
# Anthropic (Claude):  AI_API_KEY=sk-ant-api03-...
# OpenAI (GPT):        AI_API_KEY=sk-...
# Google (Gemini):     AI_API_KEY=AIza...

AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-api03-...
